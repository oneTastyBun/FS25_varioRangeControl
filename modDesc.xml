<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<modDesc descVersion="106">
    <author>oneTastyBun</author>
    <version>0.1.6.0-beta</version>

    <title>
        <en>Vario Range Control</en>
    </title>

    <description>
        <en><![CDATA[Adds support for Vario I / II operating ranges to prepared CVT tractors.

Real Fendt Vario tractors with ML transmissions use two operating ranges:
Range I for field work and Range II for transport.

This mod recreates this behaviour by allowing the driver to manually switch ranges.

The base game Fendt 300 and 500 Vario tractors have built-in support and work out of the box. Mod vehicles must be configured to support this mod.
		]]></en>
    </description>

    <iconFilename>icon.dds</iconFilename>

    <multiplayer supported="true"/>

    <extraSourceFiles>
	    <sourceFile filename="scripts/VarioRangeControl.lua"/>
        <sourceFile filename="scripts/VarioRangeControl_register.lua"/>
		<sourceFile filename="scripts/VarioRangeControlEvent.lua"/>
		<sourceFile filename="scripts/VarioRangeControlVehicleConfigs.lua"/>
		<!-- <sourceFile filename="scripts/VarioRangeControlDebug.lua"/> -->
    </extraSourceFiles>

    <actions>
        <action name="VARIO_TOGGLE_RANGE" />
    </actions>

    <inputBinding>
        <actionBinding action="VARIO_TOGGLE_RANGE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lshift KEY_1" />
        </actionBinding>
    </inputBinding>

    <l10n>
		<!-- F1 menu help text -->
		<text name="action_VARIO_TOGGLE_RANGE">
			<en>Change Vario range</en>
		</text>
		<!-- keybind text -->
		<text name="input_VARIO_TOGGLE_RANGE">
			<en>Change Vario operating range</en>
		</text>
		<!-- blinking warning -->
		<text name="warning_VARIO_RANGE_TOO_FAST">
			<en>Unable to change Vario range: Slow down!</en>
		</text>
    </l10n>
</modDesc>
