<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<modDesc descVersion="106">
    <author>oneTastyBun</author>
    <version>0.1.5.0-beta</version>

    <title>
        <en>Vario Range Control</en>
    </title>

    <description>
        <en><![CDATA[This mod is in active development. This is not an official release build. Use at your own risk.
		
Vario Range Control adds support for Fendt Vario style I / II speed ranges to CVT transmissions. Vehicles must be prepared to use this script.]]></en>
    </description>

    <iconFilename>icon.dds</iconFilename>

    <multiplayer supported="true"/>

    <extraSourceFiles>
        <sourceFile filename="scripts/VarioRangeControl_register.lua"/>
		<sourceFile filename="scripts/VarioRangeControlEvent.lua"/>
    </extraSourceFiles>

    <actions>
        <action name="VARIO_TOGGLE_RANGE" />
    </actions>

    <inputBinding>
        <actionBinding action="VARIO_TOGGLE_RANGE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lshift KEY_1" />
        </actionBinding>
    </inputBinding>

    <l10n>
		<!-- F1 menu help text -->
        <text name="input_VARIO_RANGE_I">
            <en>Change Vario speed range</en>
        </text>
        <text name="input_VARIO_RANGE_II">
            <en>Change Vario speed range</en>
        </text>
		<!-- keybind text -->
		<text name="input_VARIO_TOGGLE_RANGE">
			<en>Change Vario speed range</en>
		</text>
    </l10n>
</modDesc>
